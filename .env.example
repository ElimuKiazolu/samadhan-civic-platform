# Copy to .env and fill in real values. .env is gitignored; this file is committed as docs.

# Gemini (server-side only; never exposed to the client)
GEMINI_API_KEY=your-gemini-api-key
# Optional: override the classification model (default: gemini-2.5-flash-lite)
# GEMINI_MODEL=gemini-2.5-flash-lite

# Firebase Admin (server-side). For Cloud Run, prefer base64 transport:
#   FIREBASE_SERVICE_ACCOUNT_B64=<base64 of the service-account JSON>
# Locally, serviceAccountKey.json in the repo root is used instead.
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app

# Firebase Web (client) config — PUBLIC identifiers, exposed to the browser via
# Vite. NOT secrets. Vite bakes these at BUILD time, so on Cloud Run they must be
# supplied as Docker build args (see Dockerfile), not just runtime env.
VITE_FIREBASE_API_KEY=your-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-web-app-id
